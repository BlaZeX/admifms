---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProgrammeCard from '../components/ProgrammeCard.astro';
import NoticeCard from '../components/NoticeCard.astro';
import EventCard from '../components/EventCard.astro';
import InfoCard from '../components/InfoCard.astro';
import StatCard from '../components/StatCard.astro';
import CTASection from '../components/CTASection.astro';
import ButtonLink from '../components/ButtonLink.astro';
import { programmes } from '../data/programmes.js';
import { getCollection } from 'astro:content';
const notices = (await getCollection('notices')).sort((a,b)=>b.data.date - a.data.date).slice(0,5);
const events = (await getCollection('events')).sort((a,b)=>b.data.date - a.data.date).slice(0,3);
const whyItems = ['NEP 2020 aligned curriculum','University of Mumbai department','Strategic Mumbai location near BKC','Industry exposure','Skill development initiatives','Alumni mentoring','Placement and corporate connect','Research-driven academic environment','Recognitions and institutional achievements'];
const recognitions = ['MCX Award 2025 for Best Supporting Partner in Education, Awareness, and Financial Literacy','Best Academic Partner recognition by ISTD Mumbai Chapter','Skill Development Leadership Award 2025 by World HRD Congress','UDRF 2024-25 First Rank references as per supplied content'];
---
<BaseLayout title="Home" description="Official website of ADMIFMS, a department of the University of Mumbai focused on management and finance education since 1994.">
  <div id="dynamic-alert-banner"></div>
  <PageHero eyebrow="A Department of the University of Mumbai" title="Shaping Future Leaders in Management and Finance Since 1994" subtitle="Established as a premier department of the University of Mumbai, Alkesh Dinesh Mody Institute for Financial and Management Studies has consistently contributed to management and finance education through academic programmes, research culture, student initiatives, and industry engagement." actions={[{href:'/programmes/',label:'Explore Programmes'}, {href:'/admissions/',label:'View Admissions',variant:'secondary'}, {href:'/notices/',label:'Latest Notices',variant:'ghost'}]} />
  <section class="section"><div class="container"><SectionHeader eyebrow="Programmes" title="Academic Programmes" subtitle="Compare undergraduate, postgraduate, integrated, and doctoral pathways offered by ADMIFMS." /><div class="grid cards-3">{programmes.map((programme)=><ProgrammeCard programme={programme} />)}</div></div></section>
  <section class="section"><div class="container two-column"><div><SectionHeader eyebrow="About ADMIFMS" title="Established in 1994 at Vidyanagari Campus" /><p>ADMIFMS is a department of the University of Mumbai located at Vidyanagari Campus, Santacruz East, Mumbai, near Bandra-Kurla Complex. The institute focuses on management, finance, research, industry interaction, student committees, and student development.</p><div class="stats-row"><StatCard value="1994" label="Established" /><StatCard value="6" label="Academic programmes" note="Details as notified" /><StatCard value="Mumbai" label="Vidyanagari Campus" /></div></div><div class="card highlight-card"><h3>Admissions Highlight</h3><div id="dynamic-admissions-highlight"><p>Admission details will be updated as per University of Mumbai notifications and institute announcements.</p></div><div class="button-row"><ButtonLink href="/admissions/" label="Admissions Page" /><ButtonLink href="https://muugadmission.samarth.edu.in" label="Samarth Portal" variant="secondary" /></div></div></div></section>
  <section class="section"><div class="container"><SectionHeader eyebrow="Why ADMIFMS" title="A formal academic environment for management and finance learning" /><div class="grid cards-3">{whyItems.map((item)=><InfoCard title={item} text="Details to be updated by the institute." />)}</div></div></section>
  <section class="section"><div class="container"><SectionHeader eyebrow="Current Updates" title="Latest Notices" /><div id="dynamic-notices" class="grid cards-3">{notices.map((notice)=><NoticeCard notice={notice} />)}</div><p><a class="text-link" href="/notices/">View all notices</a></p></div></section>
  <section class="section"><div class="container"><SectionHeader eyebrow="Campus" title="Events and Student Life" /><div id="dynamic-events" class="grid cards-3">{events.map((event)=><EventCard event={event} />)}</div><p><a class="text-link" href="/student-life/">Explore student life</a></p></div></section>
  <section class="section placement-preview"><div class="container two-column"><div><SectionHeader eyebrow="Placements" title="Placement and Industry Connect" /><p>The Placement Cell supports students through internships, corporate readiness activities, recruiter engagement, and professional development. Placement-related outcomes are published only after institute approval.</p><ul><li>Internship support and student profiling</li><li>Resume building, mock interviews, and corporate grooming</li><li>Recruiter interaction and placement coordination</li></ul><ButtonLink href="/placements/" label="View Placements" /></div><div class="card"><h3>For Recruiters</h3><p>ADMIFMS offers access to students across management, finance, commerce, integrated, and doctoral academic environments in Mumbai.</p><ButtonLink href="/contact/" label="Contact Placement Cell" variant="secondary" /></div></div></section>
  <section class="section"><div class="container"><SectionHeader eyebrow="Recognitions" title="Achievements and Recognitions" subtitle="Only verified and institute-approved recognitions should remain published here." /><div class="grid cards-3">{recognitions.map((item)=><InfoCard title={item} text="Editable recognition item; supporting documentation to be maintained by the institute." />)}</div></div></section>
  <CTASection title="Plan your next step with ADMIFMS" text="Explore programmes, admissions, notices, and contact details through official institute pages." actions={[{href:'/programmes/',label:'Programmes'}, {href:'/admissions/',label:'Admissions',variant:'secondary'}, {href:'/contact/',label:'Contact',variant:'ghost'}]} />
</BaseLayout>

<script>
  import { fetchSheet, normalizeDriveLink } from '../utils/googleSheets.js';
  
  document.addEventListener('DOMContentLoaded', async () => {
    // Alerts
    const alerts = await fetchSheet('Alerts');
    if (alerts && alerts.length > 0 && alerts[0].Active === 'Yes') {
      const ac = document.getElementById('dynamic-alert-banner');
      if (ac) ac.innerHTML = `<div style="background: var(--gold-500); color: #000; padding: 0.75rem 0; text-align: center; font-weight: 700;">${alerts[0].Message}</div>`;
    }

    // Notices
    const notices = await fetchSheet('Notices');
    if (notices && notices.length > 0) {
      const nc = document.getElementById('dynamic-notices');
      if (nc) nc.innerHTML = notices.slice(0, 3).map(n => `
        <article class="card notice-card" id="${n.Category?.toLowerCase() || ''}">
          <div class="card-meta">
            <span class="badge" style="background: var(--blue-100); color: var(--navy-900);">${n.Category || 'Notice'}</span>
            ${n.Important === 'Yes' ? '<span class="badge badge-accent">Important</span>' : ''}
            <time>${n.Date || ''}</time>
          </div>
          <h3>${n.Title || ''}</h3>
          <p>${n.Description || ''}</p>
          ${n.Link ? `<a class="text-link" href="${normalizeDriveLink(n.Link)}" target="_blank" rel="noopener noreferrer">Open Link</a>` : ''}
        </article>
      `).join('');
    }

    // Events
    const events = await fetchSheet('Events');
    if (events && events.length > 0) {
      const ec = document.getElementById('dynamic-events');
      if (ec) ec.innerHTML = events.slice(0, 3).map(e => `
        <article class="card event-card">
          <div class="image-placeholder">${e.Category || 'Event'}</div>
          <div class="card-meta">
            <span class="badge" style="background: var(--blue-100); color: var(--navy-900);">${e.Category || ''}</span>
            <time>${e.Date || ''}</time>
          </div>
          <h3>${e.Title || ''}</h3>
          <p>${e.Description || ''}</p>
          <p class="muted">${e.Location || ''}</p>
        </article>
      `).join('');
    }

    // Admissions Highlight
    const admissions = await fetchSheet('Admissions');
    if (admissions && admissions.length > 0) {
      const adm = document.getElementById('dynamic-admissions-highlight');
      if (adm && admissions[0].Highlight) adm.innerHTML = `<p><strong>Update:</strong> ${admissions[0].Highlight}</p>`;
    }
  });
</script>
