---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import PageHero from "../../components/PageHero.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import FacultyCard from "../../components/FacultyCard.astro";
import InfoCard from "../../components/InfoCard.astro";
import { getCollection } from "astro:content";
const faculty = await getCollection("faculty");
---

<BaseLayout
  title="Faculty"
  description="Faculty profiles, areas of interest, achievements, and academic contact information for ADMIFMS."
>
  <PageHero
    eyebrow="Faculty"
    title="Faculty"
    subtitle="Faculty profiles, academic interests, teaching areas, achievements, and contact information."
  />
  <Breadcrumbs items={[{ label: "Faculty" }]} />
  <section class="section">
    <div class="container">
      <SectionHeader title="Director" /><article class="card director-card">
        <div class="portrait-placeholder">
          <img src="/assets/img/dr-smita-shukla.webp" />
        </div><div>
          <h3>Dr. Smita Shukla</h3>
          <p>
            <strong
              >Ph.D. (Management), NET (Management), M.B.A. (Finance), M.A.
              (Economics)</strong
            >
          </p>
          <p>
            Prof. (Dr.) Smita Shukla is the Director of Alkesh Dinesh Mody
            Institute for Financial and Management Studies, University of
            Mumbai. With expertise in Business and Finance, her academic and
            research interests include private equity, banking, foreign direct
            investment, social sector entrepreneurship, inclusive organizations,
            ESG, sustainable finance, investor behaviour, and turnaround
            strategies. Her research profile is indexed on Scopus and Google
            Scholar, with publications covering areas such as banking
            performance, credit risk, gold investor behaviour, Indian outward
            FDI, ESG ratings, sustainable finance, and management case studies.
            She has also guided doctoral research and contributed actively to
            academic leadership, institutional development, and management
            education.
          </p>
        </div>
      </article>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <SectionHeader title="Core Faculty Profiles" /><div
        id="dynamic-faculty-list"
        class="grid cards-3"
      >
        {faculty.map((member) => <FacultyCard member={member} />)}
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container grid cards-3">
      <InfoCard
        title="Visiting Faculty / Industry Experts"
        text="Details to be updated by the institute."
      /><InfoCard
        title="Faculty Achievements"
        text="Verified faculty achievements can be published after institute approval."
      /><InfoCard
        title="Faculty Office Note"
        text="For academic communication, use official contact details and institute notices."
      />
    </div>
  </section>
</BaseLayout>

<script>
  import {
    fetchSheet,
    normalizeDriveLink,
    parseRichText,
  } from "../../utils/googleSheets.js";

  const escapeHtml = (value) =>
    String(value || "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");

  const splitList = (value) =>
    String(value || "")
      .split(/\r?\n|;/)
      .map((item) => item.trim())
      .filter(Boolean);

  const renderList = (title, value) => {
    const items = splitList(value);
    if (items.length === 0) return "";

    return `
      <div class="faculty-card__section">
        <h4>${title}</h4>
        <ul>
          ${items.map((item) => `<li>${parseRichText(escapeHtml(item))}</li>`).join("")}
        </ul>
      </div>
    `;
  };

  const renderExpertise = (value) => {
    const items = splitList(value);
    if (items.length === 0) return "";

    return `
      <div class="faculty-card__section">
        <h4>Areas of Expertise</h4>
        <div class="faculty-card__tags">
          ${items.map((item) => `<span>${escapeHtml(item)}</span>`).join("")}
        </div>
      </div>
    `;
  };

  const getField = (row, names) =>
    names.map((name) => row[name]).find(Boolean) || "";

  document.addEventListener("DOMContentLoaded", async () => {
    const faculty = await fetchSheet("Faculty");
    if (faculty && faculty.length > 0) {
      const fc = document.getElementById("dynamic-faculty-list");
      if (fc) {
        fc.innerHTML = faculty
          .map((f) => {
            const name = getField(f, ["Name"]);
            const designation = getField(f, ["Designation"]);
            const email = getField(f, ["Email"]);
            const photo = getField(f, [
              "PhotoLink",
              "ProfilePic",
              "ProfilePicLink",
            ]);
            const expertise = getField(f, [
              "Expertise",
              "AreasOfExpertise",
              "Areas of Expertise",
              "Interests",
            ]);
            const publications = getField(f, [
              "ResearchPublications",
              "Research Publications",
              "Publications",
            ]);
            const awards = getField(f, [
              "AwardsHonours",
              "Awards & Honours",
              "Awards",
            ]);
            const profile = getField(f, ["ProfileLink", "CVLink"]);

            return `
          <article class="card faculty-card">
            <div class="faculty-card__header">
              ${photo ? `<img src="${normalizeDriveLink(photo)}" alt="${escapeHtml(name)}" class="faculty-card__photo"/>` : `<div class="faculty-card__photo faculty-card__photo--initials" aria-hidden="true">${escapeHtml(name?.charAt(0) || "F")}</div>`}
              <div>
                <h3>${profile ? `<a href="${normalizeDriveLink(profile)}" target="_blank" rel="noopener noreferrer">${escapeHtml(name)}</a>` : escapeHtml(name)}</h3>
                ${designation ? `<p class="faculty-card__designation">${escapeHtml(designation)}</p>` : ""}
                ${email ? `<a class="faculty-card__email" href="mailto:${escapeHtml(email)}">${escapeHtml(email)}</a>` : ""}
              </div>
            </div>
            ${renderExpertise(expertise)}
            ${renderList("Research Publications", publications)}
            ${renderList("Awards & Honours", awards)}
          </article>
        `;
          })
          .join("");
      }
    }
  });
</script>
