---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import InfoCard from '../components/InfoCard.astro';
import { getCollection } from 'astro:content';

// Fetch local publications as static fallback/initial state (SEO-friendly)
const localPublications = await getCollection('publications');
const staticPublications = localPublications.map((pub) => ({
  title: pub.data.title,
  authors: pub.data.authors,
  year: pub.data.year,
  journal: pub.data.journal,
  type: pub.data.type,
  link: pub.data.link
}));
---

<BaseLayout title="Research | ADMIFMS" description="Research overview, PhD linkage, faculty publications, seminars, projects, collaborations, and research contact at ADMIFMS.">
  <PageHero 
    eyebrow="Research" 
    title="Research" 
    subtitle="Faculty research, doctoral linkage, publications, seminars, conferences, projects, consultancy, and collaborations." 
    actions={[
      { href: '/programmes/phd/', label: 'PhD Programme' }, 
      { href: '/contact/', label: 'Research Contact', variant: 'secondary' }
    ]} 
  />
  <Breadcrumbs items={[{ label: 'Research' }]} />
  
  <section class="section" id="overview">
    <div class="container narrow">
      <SectionHeader title="Research Overview" />
      <p>ADMIFMS encourages a vibrant research culture through active faculty research, doctoral linkage programs, academic seminars, national conferences, research projects, consultancy services, and institutional collaborations. References to ICSSR, NIEPA, or other externally funded activities are added only when supported by officially approved documentation.</p>
    </div>
  </section>
  
  <section class="section">
    <div class="container grid cards-3">
      <InfoCard 
        title="PhD Research" 
        text="Detailed insights, doctoral research pathways, and guidance are available directly on our dedicated PhD programme page." 
        href="/programmes/phd/" 
      />
      <InfoCard 
        title="Conferences and Seminars" 
        text="Up-to-date details of our upcoming academic workshops, seminars, and international conferences will be updated by the institute." 
      />
      <InfoCard 
        title="Research Projects and Collaborations" 
        text="Funded research projects, industrial consultancy, and academic collaborations will be published upon approval and clearance." 
      />
    </div>
  </section>
  
  <section class="section" id="publications">
    <div class="container">
      <SectionHeader title="Faculty Publications" />
      
      <div id="publications-container">
        <!-- Render static list first (will be replaced by live spreadsheet data if available) -->
        <div id="publications-list" class="grid cards-3">
          {staticPublications.map((pub) => (
            <article class="card publication-card">
              <div class="card-meta">
                <span class="badge">{pub.type}</span>
                {pub.year && <span class="badge badge-accent">{pub.year}</span>}
              </div>
              <h3>{pub.title}</h3>
              <p class="pub-authors">
                <strong>Author(s):</strong> {pub.authors}
              </p>
              {pub.journal && (
                <p class="pub-journal">
                  <strong>Published In:</strong> {pub.journal}
                </p>
              )}
              {pub.link && (
                <div class="pub-link-wrapper">
                  <a class="text-link" href={pub.link} target="_blank" rel="noopener noreferrer">
                    View Publication
                  </a>
                </div>
              )}
            </article>
          ))}
          {staticPublications.length === 0 && (
            <p class="empty-state">Publication details to be updated by the institute.</p>
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { fetchSheet } from "../utils/googleSheets.js";

  const loadPublications = async () => {
    try {
      const sheetPublications = await fetchSheet("FacultyPublication");
      
      if (sheetPublications && sheetPublications.length > 0) {
        const publicationsList = document.getElementById("publications-list");
        if (publicationsList) {
          const dynamicHtml = sheetPublications
            .map((row) => {
              const title = row["Research Title"] || row["research title"] || row["Title"] || row["title"] || "";
              const authors = row["Faculty Name"] || row["faculty name"] || "Faculty Member";
              const year = row["Published On"] || row["published on"] || row["Year"] || row["year"] || "";
              const journal = row["Published In"] || row["published in"] || row["Journal"] || row["journal"] || "";
              const type = row["Type"] || row["type"] || "Research Paper";
              const link = row["URL"] || row["url"] || row["Link"] || row["link"] || "";

              if (!title) return ""; // Skip empty rows

              return `
                <article class="card publication-card">
                  <div class="card-meta">
                    <span class="badge">${type}</span>
                    ${year ? `<span class="badge badge-accent">${year}</span>` : ""}
                  </div>
                  <h3>${title}</h3>
                  <p class="pub-authors">
                    <strong>Author(s):</strong> ${authors}
                  </p>
                  ${journal ? `
                    <p class="pub-journal">
                      <strong>Published In:</strong> ${journal}
                    </p>
                  ` : ""}
                  ${link ? `
                    <div class="pub-link-wrapper">
                      <a class="text-link" href="${link}" target="_blank" rel="noopener noreferrer">
                        View Publication
                      </a>
                    </div>
                  ` : ""}
                </article>
              `;
            })
            .filter(Boolean)
            .join("");

          if (dynamicHtml.trim()) {
            publicationsList.innerHTML = dynamicHtml;
          }
        }
      }
    } catch (error) {
      console.error("Error fetching dynamic publications:", error);
    }
  };

  // Run load on page ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", loadPublications);
  } else {
    loadPublications();
  }
</script>

<style>
  /* Premium publication card styling matching school styling cues */
  :global(.publication-card) {
    display: flex;
    flex-direction: column;
    height: 100%;
    border-top: 5px solid var(--blue-700);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-top-color 0.25s ease;
  }

  :global(.publication-card:hover) {
    border-top-color: var(--gold-500);
    transform: translateY(-4px);
  }

  :global(.publication-card h3) {
    font-size: 1.15rem;
    line-height: 1.45;
    margin: 0.5rem 0 1rem;
    color: var(--navy-950);
    font-weight: 700;
  }

  :global(.pub-authors),
  :global(.pub-journal) {
    font-size: 0.92rem;
    color: var(--text);
    margin: 0 0 0.5rem;
    line-height: 1.5;
  }

  :global(.pub-authors strong),
  :global(.pub-journal strong) {
    color: var(--navy-800);
    font-weight: 600;
  }

  :global(.pub-link-wrapper) {
    margin-top: auto;
    padding-top: 1.25rem;
  }

  /* Make empty state text clean and muted */
  .empty-state {
    color: var(--muted);
    font-style: italic;
  }
</style>
