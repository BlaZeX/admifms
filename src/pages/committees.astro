---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout
    title="Committees"
    description="Institute committees, cells, and student bodies at ADMIFMS."
>
    <PageHero
        eyebrow="Institutional Information"
        title="Committees"
        subtitle="Institute committees, cells, and student bodies at ADMIFMS."
    />
    <Breadcrumbs items={[{ label: "Committees" }]} />
    <section class="section">
        <div class="container narrow card">
            <p>
                Committee details including placement, media, alumni, cultural,
                social responsibility, and entrepreneurship activities will be
                updated by the institute.
            </p>
        </div>
    </section>
</BaseLayout>
