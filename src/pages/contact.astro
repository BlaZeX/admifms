---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import PageHero from "../components/PageHero.astro";
import ContactCard from "../components/ContactCard.astro";
import InfoCard from "../components/InfoCard.astro";
---

<BaseLayout
    title="Contact"
    description="Contact details, address, office hours, admissions contact, enquiry form placeholder, and map link for ADMIFMS."
>
    <PageHero
        eyebrow="Contact"
        title="Contact ADMIFMS"
        subtitle="Official address, contact placeholders, programme enquiry, admission contact, and map details."
    />
    <Breadcrumbs items={[{ label: "Contact" }]} />
    <section class="section">
        <div class="container two-column">
            <ContactCard
                title="Contact"
                email="admi.inst@mu.ac.in"
                phone="022-26530134"
                address="Joravar Bhavan, Behind Saroj Sadan, University Campus, Vidya Nagari, Santacruz (East), Mumbai – 400098, Maharashtra, India."
                action={{
                    href: "google.com/maps/place/Alkesh+Dinesh+Mody+Institute+for+Financial+%26+Management+Studies/@19.074457,72.8636625,17z/data=!4m6!3m5!1s0x3be7c8e4926bb24f:0x8805c1944a8e3d3b!8m2!3d19.0696229!4d72.858461!16s%2Fg%2F1tzgh2tx?entry=ttu&g_ep=EgoyMDI2MDUxMy4wIKXMDSoASAFQAw%3D%3D",
                    label: "Open Map",
                }}
            /><div class="card">
                <h2>Office Hours</h2><p>10:00 AM - 06:00 PM</p><h2>
                    Enquiry
                </h2><p>Use the below form to reach out to us.</p><a
                    class="button button-secondary"
                    href="https://forms.gle/Lt74nEoHWafBY1o67"
                    target="_blank"
                    rel="noopener noreferrer">Contact Us</a
                >
            </div>
        </div>
    </section>
    <section class="section">
        <div class="container grid cards-3">
            <InfoCard title="Admissions Contact">
                <p>
                    <strong>Email:</strong> admission@admi.mu.ac.in
                </p>
            </InfoCard>
            <InfoCard title="Placement Cell Contact">
                <p><strong>Placement Officer:</strong> Dr. Kavita Pandey</p>
                <p>
                    <strong>Email:</strong> placements@admi.mu.ac.in / kavita@admi.mu.ac.in
                </p>
            </InfoCard>
            <InfoCard title="Social Media">
                <p style="text-align: center; font-size: 1rem;">
                    <a
                        href="http://linkedin.com/school/admifms/"
                        target="_blank"
                        rel="noopener"
                    >
                        <svg
                            class="w-6 h-6 text-gray-800 dark:text-white"
                            aria-hidden="true"
                            xmlns="http://www.w3.org/2000/svg"
                            width="64"
                            height="64"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M12.51 8.796v1.697a3.738 3.738 0 0 1 3.288-1.684c3.455 0 4.202 2.16 4.202 4.97V19.5h-3.2v-5.072c0-1.21-.244-2.766-2.128-2.766-1.827 0-2.139 1.317-2.139 2.676V19.5h-3.19V8.796h3.168ZM7.2 6.106a1.61 1.61 0 0 1-.988 1.483 1.595 1.595 0 0 1-1.743-.348A1.607 1.607 0 0 1 5.6 4.5a1.601 1.601 0 0 1 1.6 1.606Z"
                                clip-rule="evenodd"></path>
