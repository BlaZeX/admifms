  }

  @keyframes marquee-loop {
    0% {
      transform: translateX(0);
    }
    100% {
      /* Shift by exactly half (1 list) plus half of the gap offset */
      transform: translateX(calc(-50% - 2rem));
    }
  }

  /* Skeleton Loading Styles */
  .placements-loader-container {
    width: 100%;
    margin-bottom: 4.5rem;
  }

  .skeleton-wrapper {
    display: flex;
