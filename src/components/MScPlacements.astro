<div class="msc-placements-wrapper" id="msc-placements-root">
  <!-- Placements Section (Dynamically Loaded) -->
  <div id="placements-container" class="placements-section hidden">
    <div class="section-header">
      <h2>MSc. Students Placed</h2>
      <p>
        Our students are placed in top tier financial institutions, analytics
        firms and corporate treasury offices. Here is the academic year-wise
        placement overview.
      </p>
    </div>

    <div class="table-card">
      <div class="table-responsive">
        <table class="styled-table">
          <thead>
            <tr>
              <th scope="col" style="width: 100px;">Sr No.</th>
              <th scope="col">Academic Year</th>
              <th scope="col">Highest CTC</th>
              <th scope="col">Average CTC</th>
            </tr>
          </thead>
          <tbody id="placements-tbody">
            <!-- Populated dynamically client-side -->
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Recruiters Section (Dynamically Loaded) -->
  <div id="recruiters-container" class="recruiters-section hidden">
    <div class="section-header">
      <h2>Key Recruiters</h2>
      <p>
        Leading organizations that regularly recruit from our MSc. Finance
        programme.
      </p>
    </div>

    <div class="marquee-wrapper">
      <div class="marquee-content" id="recruiters-marquee">
        <!-- Populated dynamically client-side -->
      </div>
    </div>
  </div>

  <!-- Client-Side Skeleton Loader -->
  <div id="placements-loader" class="placements-loader-container">
    <div class="skeleton-wrapper">
      <div class="skeleton-header"></div>
      <div class="skeleton-table"></div>
    </div>
  </div>
</div>

<script>
  import { fetchSheet, normalizeDriveLink } from "../utils/googleSheets.js";

  const loadDynamicData = async () => {
    try {
      const [placements, recruiters] = await Promise.all([
        fetchSheet("MSc_Placements"),
        fetchSheet("MSc_Recruiters"),
      ]);

      const placementsContainer = document.getElementById(
        "placements-container",
      );
      const recruitersContainer = document.getElementById(
        "recruiters-container",
      );
      const loader = document.getElementById("placements-loader");

      if (placements && placements.length > 0) {
        const tbody = document.getElementById("placements-tbody");
        if (tbody) {
          tbody.innerHTML = placements
            .map((row) => {
              const srNo =
                row["Sr No."] || row["sr no."] || row["Sr. No."] || "-";
              const academicYear =
                row["Academic Year"] || row["academic year"] || "-";
              const highestCtc =
                row["Highest CTC"] || row["highest ctc"] || "-";
              const averageCtc =
                row["Average CTC"] || row["average ctc"] || "-";

              return `
                <tr>
                  <td class="sr-no" style="text-align: center;">${srNo}</td>
                  <td class="academic-year" style="text-align: center;">${academicYear}</td>
                  <td class="ctc highest-ctc" style="text-align: center;">${highestCtc}</td>
                  <td class="ctc average-ctc" style="text-align: center;">${averageCtc}</td>
                </tr>
              `;
            })
            .join("");

          placementsContainer.classList.remove("hidden");
        }
      }

      if (recruiters && recruiters.length > 0) {
        const marquee = document.getElementById("recruiters-marquee");
        if (marquee) {
          const recruiterHtml = recruiters
            .map((recruiter) => {
              const logoUrl =
                recruiter["Logo URL"] || recruiter["logo url"] || "";
              const companyName =
                recruiter["Company Name"] ||
                recruiter["company name"] ||
                "Recruiter";

              return `
                <div class="recruiter-logo" title="${companyName}">
                  ${
                    logoUrl
                      ? `<img src="${normalizeDriveLink(logoUrl)}" alt="${companyName} Logo" loading="lazy" />`
                      : `<span class="company-text">${companyName}</span>`
                  }
                </div>
              `;
            })
            .join("");

          // Duplicate the list of logos for infinite marquee effect
          marquee.innerHTML = recruiterHtml + recruiterHtml;
          recruitersContainer.classList.remove("hidden");
        }
      }

      if (loader) {
        loader.classList.add("hidden");
      }
    } catch (error) {
      console.error("Error loading placements dynamically:", error);
      const loader = document.getElementById("placements-loader");
      if (loader) loader.classList.add("hidden");
    }
  };

  // Run on page load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", loadDynamicData);
  } else {
    loadDynamicData();
  }
</script>

<style>
