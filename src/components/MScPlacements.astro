---
import { fetchSheet, normalizeDriveLink } from "../utils/googleSheets.js";

// Fetch the placement data and recruiters list from Google Sheets
const placements = await fetchSheet("MSc_Placements");
const recruiters = await fetchSheet("MSc_Recruiters");

const hasPlacements = placements && placements.length > 0;
const hasRecruiters = recruiters && recruiters.length > 0;
---

{
  hasPlacements && (
    <div class="placements-section">
      <div class="section-header">
        <h2>MSc. Students Placed</h2>
        <p>
          Our students are placed in top tier financial institutions, analytics
          firms and corporate treasury offices. Here is the academic year-wise
          placement overview.
        </p>
      </div>

      <div class="table-card">
        <div class="table-responsive">
          <table class="styled-table">
            <thead>
              <tr>
                <th scope="col" style="width: 100px;">
                  Sr No.
                </th>
                <th scope="col">Academic Year</th>
                <th scope="col">Highest CTC</th>
                <th scope="col">Average CTC</th>
              </tr>
            </thead>
            <tbody>
              {placements.map((row) => (
                <tr>
                  <td class="sr-no">
                    {row["Sr No."] || row["sr no."] || row["Sr. No."] || "-"}
                  </td>
                  <td class="academic-year">
                    {row["Academic Year"] || row["academic year"] || "-"}
                  </td>
                  <td class="ctc highest-ctc">
                    {row["Highest CTC"] || row["highest ctc"] || "-"}
                  </td>
                  <td class="ctc average-ctc">
                    {row["Average CTC"] || row["average ctc"] || "-"}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  )
}

{
  hasRecruiters && (
    <div class="recruiters-section">
      <div class="section-header">
        <h2>Key Recruiters</h2>
        <p>
          Leading organizations that regularly recruit from our MSc. Finance
          programme.
        </p>
      </div>

      <div class="marquee-wrapper">
        <div class="marquee-content">
          {recruiters.map((recruiter) => {
            const logoUrl =
              recruiter["Logo URL"] || recruiter["logo url"] || "";
            const companyName =
              recruiter["Company Name"] ||
              recruiter["company name"] ||
              "Recruiter";
            return (
              <div class="recruiter-logo" title={companyName}>
                {logoUrl ? (
                  <img
                    src={normalizeDriveLink(logoUrl)}
                    alt={`${companyName} Logo`}
                    loading="lazy"
                  />
                ) : (
                  <span class="company-text">{companyName}</span>
                )}
              </div>
            );
          })}
          {/* Duplicate the items to allow continuous looping */}
          {recruiters.map((recruiter) => {
            const logoUrl =
              recruiter["Logo URL"] || recruiter["logo url"] || "";
            const companyName =
              recruiter["Company Name"] ||
              recruiter["company name"] ||
              "Recruiter";
            return (
              <div class="recruiter-logo" title={companyName}>
                {logoUrl ? (
                  <img
                    src={normalizeDriveLink(logoUrl)}
                    alt={`${companyName} Logo`}
                    loading="lazy"
                  />
                ) : (
                  <span class="company-text">{companyName}</span>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </div>
  )
}

<style>
  .placements-section {
    margin-bottom: 4.5rem;
  }

  .recruiters-section {
    margin-bottom: 4.5rem;
  }

  /* Section Header styling to match current site */
  .section-header {
    max-width: 820px;
    margin: 0 0 2rem;
  }

  .section-header h2 {
    position: relative;
    padding-bottom: 14px;
    margin-bottom: 12px;
    color: var(--navy-950);
    font-family: "Outfit", sans-serif;
    font-size: clamp(1.45rem, 2.5vw, 2.25rem);
    font-weight: 700;
  }

  .section-header h2::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 60px;
    height: 3px;
    background-color: var(--blue-700);
  }

  .section-header p {
    color: var(--muted);
    font-size: 1.05rem;
    margin-top: 0.8rem;
    line-height: 1.6;
  }

  /* Table styles */
  .table-card {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem;
    box-shadow: rgba(0, 0, 0, 0.04) 0px 4px 20px 0px;
    overflow: hidden;
  }

  .table-responsive {
    overflow-x: auto;
    width: 100%;
    -webkit-overflow-scrolling: touch;
  }

  .styled-table {
    width: 100%;
    border-collapse: collapse;
    font-family: "Plus Jakarta Sans", sans-serif;
  }

  .styled-table th {
    background-color: var(--navy-950);
    color: #ffffff;
    text-align: left;
    padding: 1rem 1.25rem;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
  }

  .styled-table th:first-child {
    border-top-left-radius: 6px;
    border-bottom-left-radius: 6px;
  }

  .styled-table th:last-child {
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
  }

  .styled-table td {
    padding: 1.1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    font-size: 0.95rem;
  }

  /* Responsive Table Styling for Small Screens */
  @media (max-width: 768px) {
    .styled-table th,
    .styled-table td {
      padding: 0.8rem 0.75rem;
      font-size: 0.88rem;
    }
  }

  @media (max-width: 480px) {
    .table-card {
      padding: 0.5rem;
    }

    .styled-table th,
    .styled-table td {
      padding: 0.65rem 0.5rem;
      font-size: 0.8rem;
    }

    /* Adjust the specific width of Sr No. col on extra small screens */
    .styled-table th[style] {
      width: 65px !important;
    }
  }

  .styled-table tbody tr:last-child td {
    border-bottom: none;
  }

  .styled-table tbody tr {
    transition: background-color 0.2s ease;
  }

  .styled-table tbody tr:hover {
    background-color: rgba(57, 73, 171, 0.04);
  }

  .sr-no {
    font-weight: 600;
    color: var(--muted);
  }

  .academic-year {
    font-weight: 700;
    color: var(--navy-950);
  }

  .ctc {
    font-weight: 600;
  }

  .highest-ctc {
    color: var(--green-700);
  }

  .average-ctc {
    color: var(--blue-700);
  }

  /* Infinite Scrolling Marquee */
  .marquee-wrapper {
    overflow: hidden;
    position: relative;
    width: 100%;
    padding: 2.25rem 0;
    background-color: var(--surface-soft);
    border: 1px solid var(--border);
    border-radius: 12px;
    display: flex;
    align-items: center;
  }

  /* Fade gradient overlays on left and right for seamless look */
  .marquee-wrapper::before,
  .marquee-wrapper::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 100px;
    z-index: 2;
    pointer-events: none;
  }

  .marquee-wrapper::before {
    left: 0;
    background: linear-gradient(to right, var(--surface-soft), transparent);
  }

  .marquee-wrapper::after {
    right: 0;
    background: linear-gradient(to left, var(--surface-soft), transparent);
  }

  .marquee-content {
    display: flex;
    gap: 4rem;
    animation: marquee-loop 30s linear infinite;
    white-space: nowrap;
    will-change: transform;
    align-items: center;
  }

  .marquee-wrapper:hover .marquee-content {
    animation-play-state: paused;
  }

  .recruiter-logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 160px;
    height: 70px;
    padding: 0.5rem;
    background-color: #ffffff;
    border: 1px solid var(--border);
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .recruiter-logo:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
  }

  .recruiter-logo img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.7;
    transition: all 0.3s ease;
  }

  .recruiter-logo:hover img {
    filter: grayscale(0%);
    opacity: 1;
  }

  .company-text {
    font-weight: 700;
    color: var(--navy-950);
    font-size: 0.9rem;
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    width: 100%;
  }

  @keyframes marquee-loop {
    0% {
      transform: translateX(0);
    }
    100% {
      /* Shift by exactly half (1 list) plus half of the gap offset */
      transform: translateX(calc(-50% - 2rem));
    }
  }
</style>
