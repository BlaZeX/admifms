---
import ButtonLink from './ButtonLink.astro';
const { title = 'Need more information?', text = 'Details will be updated by the institute. For enquiries, please use the official contact channels.', actions = [{ href: '/contact/', label: 'Contact ADMIFMS' }] } = Astro.props;
---
<section class="section cta-band">
  <div class="container cta-inner">
    <div><h2>{title}</h2><p>{text}</p></div>
    <div class="button-row">{actions.map((action) => <ButtonLink {...action} />)}</div>
  </div>
</section>
