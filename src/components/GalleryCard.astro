---
import Badge from './Badge.astro';
const { item } = Astro.props;
---
<article class="card gallery-card">
  <div>
    {item.data.coverImage ? (
      <img src={item.data.coverImage} alt={item.data.title} class="image-placeholder" style="width:100%; height:200px; object-fit:cover; border:none; background:none; border-bottom:1px solid var(--border);" />
    ) : (
      <div class="image-placeholder" aria-label={`Gallery placeholder for ${item.data.title}`} style="height:200px; display:grid; place-items:center; background:var(--surface-soft); color:var(--muted); font-weight:600; border-bottom:1px solid var(--border);">Photo album</div>
    )}
    <div style="padding: 1.5rem 1.5rem 0.5rem 1.5rem;">
      <div class="card-meta" style="margin-bottom:0.6rem; display:flex; justify-content:space-between; align-items:center; width:100%;">
        <Badge label={item.data.category} />
        <time>{item.data.date.toLocaleDateString('en-IN')}</time>
      </div>
      <h3 style="margin-top:0.5rem; margin-bottom:0.5rem; font-size:1.2rem; color:var(--navy-950);">{item.data.title}</h3>
      <p class="muted" style="margin-bottom:0; font-size:0.95rem; line-height:1.5;">{item.data.description}</p>
    </div>
  </div>
  {item.data.galleryLink && (
    <div style="padding: 0 1.5rem 1.5rem 1.5rem; margin-top: 1rem;">
      <a class="button button-secondary" href={item.data.galleryLink} target="_blank" rel="noopener noreferrer" style="font-size:0.85rem; padding:0.5rem 1.2rem; width:100%; text-align:center; display:inline-block; border-color:var(--navy-950); color:var(--navy-950); font-weight:700;">
        Open Photo Album
      </a>
    </div>
  )}
</article>
