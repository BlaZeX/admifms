---
import ButtonLink from './ButtonLink.astro';
const { title = 'Contact', email = 'Details to be updated by the institute.', phone = 'Details to be updated by the institute.', address, action } = Astro.props;
---
<article class="card contact-card"><h2>{title}</h2><p><strong>Email:</strong> {email}</p><p><strong>Phone:</strong> {phone}</p>{address && <p><strong>Address:</strong> {address}</p>}{action && <ButtonLink {...action} />}</article>
