---
const { member } = Astro.props;
---
<article class="card faculty-card">
  <div class="avatar-placeholder" aria-hidden="true">{member.data.name.split(' ').map((part) => part[0]).slice(0,2).join('')}</div>
  <h3><a href={`/faculty/${member.slug}/`}>{member.data.name}</a></h3>
  <p><strong>{member.data.designation}</strong></p>
  <p>{member.data.qualification}</p>
  <p class="muted">Areas: {member.data.areas.join(', ')}</p>
  <a href={`mailto:${member.data.email}`}>{member.data.email}</a>
</article>
