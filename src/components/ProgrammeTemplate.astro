---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import PageHero from './PageHero.astro';
import SectionHeader from './SectionHeader.astro';
import AtGlanceGrid from './AtGlanceGrid.astro';
import FAQList from './FAQList.astro';
import CTASection from './CTASection.astro';
import Badge from './Badge.astro';
import MScPlacements from './MScPlacements.astro';

const { programme } = Astro.props;

const faqs = [
  { question: `What is the admission route for ${programme.shortTitle}?`, answer: programme.admissionRoute || 'Details will be updated as per University of Mumbai and institute notifications.' },
  { question: 'What is the eligibility?', answer: programme.eligibility || 'Details to be updated by the institute.' },
  { question: 'What is the intake?', answer: programme.intake || 'Details to be updated by the institute.' },
  { question: 'Where can fee details be found?', answer: programme.feesNote || 'Fee details will be updated as per University of Mumbai and institute notifications.' },
  { question: 'Whom should applicants contact?', answer: programme.contactInfo || 'Programme contact details will be updated by the institute.' }
];

const glance = [
  { label: 'Duration', value: programme.duration, icon: 'ti ti-calendar-time' },
  { label: 'Level', value: programme.level, icon: 'ti ti-award' },
  { label: 'Mode', value: programme.mode || 'Full-time', icon: 'ti ti-clock' },
  { label: 'Eligibility', value: programme.eligibility || 'Eligibility Criteria as per University of Mumbai guidelines and notifications.', icon: 'ti ti-certificate' },
  { label: 'Intake', value: programme.intake || 'Details to be updated by the institute.', icon: 'ti ti-users' },
  { label: 'Affiliation', value: 'University of Mumbai', icon: 'ti ti-building-columns' },
  { label: 'Admission route', value: programme.admissionRoute || 'As per University of Mumbai and institute notifications.', icon: 'ti ti-route' }
];

const placementSections = {
  'msc-finance': {
    placementsSheet: 'MSc_Placements',
    recruitersSheet: 'MSc_Recruiters',
    placementTitle: 'MSc. Students Placed',
    placementDescription: 'Our students are placed in top tier financial institutions, analytics firms and corporate treasury offices. Here is the academic year-wise placement overview.',
    recruitersTitle: 'Key Recruiters',
    recruitersDescription: 'Leading organizations that regularly recruit from our MSc. Finance programme.'
  },
  mms: {
    placementsSheet: 'MMS_Placements',
    recruitersSheet: 'MMS_Recruiters',
    placementTitle: 'MMS Students Placed',
    placementDescription: 'Our MMS students are placed across management, finance, marketing, HR, operations, analytics, and allied business roles. Here is the academic year-wise placement overview.',
    recruitersTitle: 'Key Recruiters',
    recruitersDescription: 'Leading organizations that recruit from our MMS programme.'
  }
};

const placementSection = placementSections[programme.slug];
---
<BaseLayout title={`${programme.title} | ADMIFMS`} description={programme.description}>
  <PageHero eyebrow="Programme" title={programme.title} subtitle={programme.description} actions={[{ href: '/admissions/', label: 'Apply / Enquire' }, { href: '/contact/', label: 'Programme Contact', variant: 'secondary' }]} />
  <Breadcrumbs items={[{ label: 'Programmes', href: '/programmes/' }, { label: programme.shortTitle }]} />
  
  <section class="section">
    <div class="container narrow">
      <div class="card programme-intro">
        <div class="card-meta">
          <Badge label={programme.degreeType} />
          <Badge label={programme.level} />
          {programme.isNew && <Badge label="New Programme" tone="accent" />}
        </div>
        <h2>At a Glance</h2>
        <AtGlanceGrid items={glance} />
      </div>
    </div>
  </section>
  
  <section class="section">
    <div class="container two-column">
      <article>
        <SectionHeader title="Programme Overview" />
        <p>{programme.overview}</p>
        
        <h2>Who Should Apply</h2>
        <ul>
          {programme.whoShouldApply.map((item) => <li>{item}</li>)}
        </ul>
        
        <h2>Curriculum / Course Structure</h2>
        <ul>
          {programme.curriculum.map((item) => <li>{item}</li>)}
        </ul>
        
        {programme.slug === 'bcom-retail-operations-management' && (
          <>
            <h2>Samarth Portal Registration Guidance</h2>
            <p>Students are required to complete registration and application formalities through the University of Mumbai admission portal as notified. Detailed step-by-step guidance will be updated by the institute.</p>
          </>
        )}
        
        <h2>Learning Outcomes</h2>
        <ul>
          {programme.outcomes.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      
      <aside class="card">
        <h2>Teaching-Learning Approach</h2>
        <ul>
          {programme.teaching.map((item) => <li>{item}</li>)}
        </ul>
        
        <h2>Career Pathways</h2>
        <ul>
          {programme.careers.map((item) => <li>{item}</li>)}
        </ul>
      </aside>
    </div>
  </section>
  
  {placementSection && (
    <section class="section">
      <div class="container">
        <MScPlacements {...placementSection} />
      </div>
    </section>
  )}

  <section class="section">
    <div class="container">
      <SectionHeader title="Admission Process and Fees" />
      <div class="grid cards-3">
        <article class="card">
          <h3>Admission Process</h3>
          <p>{programme.admissionProcess}</p>
        </article>
        <article class="card">
          <h3>Fees Note</h3>
          <p>{programme.feesNote}</p>
        </article>
        <article class="card">
          <h3>Programme Contact</h3>
          <p>{programme.contactInfo}</p>
        </article>
      </div>
    </div>
  </section>
  
  <section class="section">
    <div class="container narrow">
      <SectionHeader title="Frequently Asked Questions" />
      <FAQList faqs={faqs} />
    </div>
  </section>
  
  <!-- Slot for rendering any unique program-specific layout, tables, or sections passed from individual pages -->
  <slot />

  <CTASection title="Interested in this programme?" text="Admission details will be updated as per University of Mumbai notifications and institute announcements." actions={[{ href: '/admissions/', label: 'View Admissions' }, { href: '/contact/', label: 'Contact ADMIFMS', variant: 'secondary' }]} />
</BaseLayout>
