---
const { item } = Astro.props;
const dateLabel = item.data.date ? item.data.date.toLocaleDateString('en-IN') : item.data.year;
---
<article class="card download-card"><h3>{item.data.title}</h3><p class="muted">{item.data.category} · {dateLabel}</p>{item.data.description && <p>{item.data.description}</p>}<a class="text-link" href={item.data.fileUrl} target="_blank" rel="noopener noreferrer">Download</a></article>
